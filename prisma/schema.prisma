generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum ArticleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum MediaStatus {
  LIVE
  HIDDEN
}

enum BookStatus {
  SHOW
  HIDDEN
}

// ============================================
// AUTH
// ============================================

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// CONTENT
// ============================================

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  articles  Article[] @relation("ArticleTags")
}

model Article {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  content          String        @db.Text
  excerpt          String        @default("")
  featuredImage    String?
  featuredImageAlt String?
  category         String        @default("osint")
  tags             Tag[]         @relation("ArticleTags")
  seoKeywords      Json          @default("[]")
  metaTitle        String?
  metaDescription  String?
  author           String        @default("Romullo Carvalho")
  featured         Boolean       @default(false)
  status           ArticleStatus @default(DRAFT)
  viewsCount       Int           @default(0)
  readingTime      Int           @default(1)
  scheduledAt      DateTime?
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@index([category])
}

model Short {
  id           String      @id @default(cuid())
  title        String
  description  String      @default("")
  youtubeUrl   String
  thumbnailUrl String?
  categoryTags Json        @default("[]")
  status       MediaStatus @default(LIVE)
  dateAdded    DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model InstagramPost {
  id              String      @id @default(cuid())
  title           String
  description     String      @default("")
  instagramUrl    String
  imageUrl        String?
  captionOverride String?     @db.Text
  categoryTags    Json        @default("[]")
  status          MediaStatus @default(LIVE)
  dateAdded       DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Book {
  id             String     @id @default(cuid())
  title          String
  author         String
  coverImage     String?
  affiliateLink  String?
  category       String     @default("osint")
  description    String     @default("") @db.Text
  showOnHomepage Boolean    @default(true)
  status         BookStatus @default(SHOW)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Faq {
  id           String   @id @default(cuid())
  question     String
  answer       String   @db.Text
  category     String   @default("general")
  displayOrder Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, displayOrder])
}

model PageSeo {
  id          String   @id @default(cuid())
  pageKey     String   @unique
  title       String
  description String   @db.Text
  ogTitle     String?
  ogDesc      String?
  noIndex     Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model SiteConfig {
  id                String   @id @default("default")
  siteTitle         String   @default("RC Perito Digital")
  metaDescription   String   @default("") @db.Text
  primaryKeywords   Json     @default("[]")
  googleAnalyticsId String?
  socialLinks       Json     @default("{}")
  logoUrl           String?
  faviconUrl        String?
  contactEmail      String?
  whatsapp          String?
  timezone          String   @default("America/Fortaleza")
  maintenanceMode   Boolean  @default(false)
  updatedAt         DateTime @updatedAt
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  status       String   @default("ACTIVE")
  subscribedAt DateTime @default(now())
}
